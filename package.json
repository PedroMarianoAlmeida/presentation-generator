{
  "name": "presentation-generator",
  "version": "1.0.0",
  "description": "Project to help of generate and publish pdfs and images using react",
  "license": "MIT",
  "author": "Pedro Almeida",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "node --import tsx/esm src/scripts/build/build.tsx",
    "watch": "nodemon --watch src --ext ts,tsx --exec \"npm run build\"",
    "publish": "node --import tsx/esm src/scripts/publish/publish.ts"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.0",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.4.1",
    "nodemon": "^3.1.10",
    "pdf-to-img": "^5.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "tsx": "^4.0.0"
  }
}
